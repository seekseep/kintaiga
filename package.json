{
  "name": "kintaiga",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "wireit",
    "build": "wireit",
    "typecheck": "wireit",
    "lint": "wireit",
    "preview": "vite preview",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "wireit": {
    "dev": {
      "command": "vercel dev",
      "service": true
    },
    "build": {
      "command": "vite build",
      "dependencies": [
        "typecheck"
      ],
      "files": [
        "src/**",
        "index.html",
        "vite.config.ts",
        "tsconfig*.json"
      ],
      "output": [
        "dist/**"
      ]
    },
    "typecheck": {
      "command": "tsc -b",
      "files": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "tsconfig*.json"
      ],
      "output": []
    },
    "lint": {
      "command": "oxlint",
      "files": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "api/**/*.ts",
        "db/**/*.ts"
      ],
      "output": []
    }
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@supabase/supabase-js": "^2.100.0",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-table": "^8.21.3",
    "axios": "^1.13.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "jose": "^6.2.2",
    "lucide-react": "^1.7.0",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.8",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.2",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.6.20",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.10",
    "oxlint": "^1.57.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "vercel": "^50.37.0",
    "vite": "^8.0.1",
    "wireit": "^0.14.12"
  }
}
